FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// The SWE solver is fully explicit (RK4 / CN / Euler).
// No matrix solvers are actually used -- all updates are done via fvc operators.
// This file is kept for OpenFOAM compatibility.

solvers
{
    // Dummy entries -- not used by explicit scheme
    zeta
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0;
    }

    qFlux
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0;
    }
}

