FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);   // lake starts at rest

boundaryField
{
    // Closed lake — no-normal-flow walls
    west   { type slip; }
    east   { type slip; }
    south  { type slip; }
    north  { type slip; }
    front  { type empty; }
    back   { type empty; }
}

