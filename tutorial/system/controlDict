FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     shallowWaterFoam;

startFrom       latestTime;
startTime       0;

stopAt          endTime;
endTime         1000;          // 24 hours [s]  — matches wind duration window

deltaT          1;             // initial time step [s]; adjusted by CFL control

writeControl    adjustableRunTime;
writeInterval   1;           // write every hour (24 snapshots)

purgeWrite      0;

writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;
maxCo           0.5;            // wave-speed Courant number limit
maxDeltaT       60;             // hard upper bound on deltaT [s]

// ************************************************************************* //
