FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// Explicit shallow water solver — Euler / RK4 / CN all bypass fvm::ddt
// (the Euler step uses fvm::ddt but with explicit coefficients only).
// Linear central schemes are appropriate for smooth lake dynamics.

ddtSchemes
{
    default         Euler;      // used only in eulerStep; rk4/cn are fully explicit
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default             none;
    div(phi,U)                          Gauss linearUpwind grad(U);
    div((interpolate(hU)&S),U)          Gauss linearUpwind grad(U);
    div(-phi)                           Gauss linear;
    div(-(interpolate(hU)&S))           Gauss linear;
}

laplacianSchemes
{
    default             Gauss linear corrected;
}

interpolationSchemes
{
    default             linear;
}

snGradSchemes
{
    default             corrected;
}

